# ============================================================
# SIP Sherlock — Root .gitignore
# ============================================================

# ----- Secrets & Environment --------------------------------
**/.env
**/.env.*
!**/.env.example

# ----- Python -----------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
*.log

# ----- Node / Frontend --------------------------------------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ----- Logs -------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- OS ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----- IDE --------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
